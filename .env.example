# Anthropic API Key — required.
ANTHROPIC_API_KEY=your-api-key-here

# Model is selected per-debate in the web UI (Launch screen).
# The CLI (`python -m src.main`) falls back to claude-sonnet-4-6 if MODEL_NAME
# is not set — set it here only if you want a different CLI default.
# MODEL_NAME=claude-sonnet-4-6
